  "resources": [
    {
      "mode": "data",
      "type": "template_file",
      "name": "user_data",
      "provider": "provider[\"registry.terraform.io/hashicorp/template\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "filename": null,
            "id": "a222617b3d19e3af64938469f38884dc047d62b6df9cf3888349e4301bc7cb01",
            "rendered": "#cloud-config\n\npreserve_hostname: false\n\nusers:\n  - name: ubuntu\n    sudo: ALL=(ALL) NOPASSWD:ALL\n    groups: users, admin, sudo\n    shell: /bin/bash\n    lock_passwd: false\n    ssh_authorized_keys:\n      - ssh-rsa  sadok@sadok-G5-MF\n\n\nchpasswd:\n  list: |\n    ubuntu:ubuntu\n  expire: false\n\npackage_update: true\npackage_upgrade: true\npackages:\n  - qemu-guest-agent\n  - curl\n  - wget\n  - vim\n  - net-tools\n  - ca-certificates\n  - gnupg\n  - lsb-release\n  - open-iscsi          # For Longhorn\n  - nfs-common          # For NFS storage\n  - jq                  # Useful for scripts\n  - util-linux          # For disk management\n\nnetwork:\n  version: 2\n  ethernets:\n    ens3:\n      dhcp4: true\n      dhcp6: false\n\nswap:\n  filename: /swap.img\n  size: 0\n\nbootcmd:\n  - [ cloud-init-per, once, swapoff, swapoff, -a ]\n\nruncmd:\n  # Disable swap\n  - swapoff -a\n  - sed -i '/ swap / s/^/#/' /etc/fstab\n  \n  # Enable services\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n  - systemctl enable iscsid\n  - systemctl start iscsid\n  \n  # Kernel modules for k8s\n  - modprobe overlay\n  - modprobe br_netfilter\n  - echo \"overlay\" \u003e\u003e /etc/modules-load.d/k8s.conf\n  - echo \"br_netfilter\" \u003e\u003e /etc/modules-load.d/k8s.conf\n  \n  # Sysctl for k8s\n  - echo \"net.bridge.bridge-nf-call-iptables = 1\" \u003e\u003e /etc/sysctl.conf\n  - echo \"net.bridge.bridge-nf-call-ip6tables = 1\" \u003e\u003e /etc/sysctl.conf\n  - echo \"net.ipv4.ip_forward = 1\" \u003e\u003e /etc/sysctl.conf\n  - echo \"fs.inotify.max_user_instances = 8192\" \u003e\u003e /etc/sysctl.conf\n  - echo \"fs.inotify.max_user_watches = 524288\" \u003e\u003e /etc/sysctl.conf\n  - sysctl -p\n  \n  # Prepare additional disk for Longhorn if exists (will be /dev/vdb)\n  - |\n    if [ -b /dev/vdb ]; then\n      # Format the disk as ext4\n      mkfs.ext4 -F /dev/vdb\n      # Create mount point\n      mkdir -p /var/lib/longhorn\n      # Get UUID\n      UUID=$(blkid -s UUID -o value /dev/vdb)\n      # Add to fstab\n      echo \"UUID=$UUID /var/lib/longhorn ext4 defaults 0 2\" \u003e\u003e /etc/fstab\n      # Mount\n      mount -a\n      # Set permissions\n      chmod 755 /var/lib/longhorn\n    fi\n\ntimezone: Africa/Tunis\n\nfinal_message: \"Cloud-init completed in $UPTIME seconds\"\n",
            "template": "#cloud-config\n\npreserve_hostname: false\n\nusers:\n  - name: ubuntu\n    sudo: ALL=(ALL) NOPASSWD:ALL\n    groups: users, admin, sudo\n    shell: /bin/bash\n    lock_passwd: false\n    ssh_authorized_keys:\n      - ${ssh_public_key}\n\nchpasswd:\n  list: |\n    ubuntu:ubuntu\n  expire: false\n\npackage_update: true\npackage_upgrade: true\npackages:\n  - qemu-guest-agent\n  - curl\n  - wget\n  - vim\n  - net-tools\n  - ca-certificates\n  - gnupg\n  - lsb-release\n  - open-iscsi          # For Longhorn\n  - nfs-common          # For NFS storage\n  - jq                  # Useful for scripts\n  - util-linux          # For disk management\n\nnetwork:\n  version: 2\n  ethernets:\n    ens3:\n      dhcp4: true\n      dhcp6: false\n\nswap:\n  filename: /swap.img\n  size: 0\n\nbootcmd:\n  - [ cloud-init-per, once, swapoff, swapoff, -a ]\n\nruncmd:\n  # Disable swap\n  - swapoff -a\n  - sed -i '/ swap / s/^/#/' /etc/fstab\n  \n  # Enable services\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n  - systemctl enable iscsid\n  - systemctl start iscsid\n  \n  # Kernel modules for k8s\n  - modprobe overlay\n  - modprobe br_netfilter\n  - echo \"overlay\" \u003e\u003e /etc/modules-load.d/k8s.conf\n  - echo \"br_netfilter\" \u003e\u003e /etc/modules-load.d/k8s.conf\n  \n  # Sysctl for k8s\n  - echo \"net.bridge.bridge-nf-call-iptables = 1\" \u003e\u003e /etc/sysctl.conf\n  - echo \"net.bridge.bridge-nf-call-ip6tables = 1\" \u003e\u003e /etc/sysctl.conf\n  - echo \"net.ipv4.ip_forward = 1\" \u003e\u003e /etc/sysctl.conf\n  - echo \"fs.inotify.max_user_instances = 8192\" \u003e\u003e /etc/sysctl.conf\n  - echo \"fs.inotify.max_user_watches = 524288\" \u003e\u003e /etc/sysctl.conf\n  - sysctl -p\n  \n  # Prepare additional disk for Longhorn if exists (will be /dev/vdb)\n  - |\n    if [ -b /dev/vdb ]; then\n      # Format the disk as ext4\n      mkfs.ext4 -F /dev/vdb\n      # Create mount point\n      mkdir -p /var/lib/longhorn\n      # Get UUID\n      UUID=$(blkid -s UUID -o value /dev/vdb)\n      # Add to fstab\n      echo \"UUID=$UUID /var/lib/longhorn ext4 defaults 0 2\" \u003e\u003e /etc/fstab\n      # Mount\n      mount -a\n      # Set permissions\n      chmod 755 /var/lib/longhorn\n    fi\n\ntimezone: Africa/Tunis\n\nfinal_message: \"Cloud-init completed in $UPTIME seconds\"\n",
            "vars": {
